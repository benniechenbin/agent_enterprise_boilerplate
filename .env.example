# Generated from app.config.settings.Settings.
# Do not add real secrets to this file.

# Application name used in logs and runtime metadata.
APP_NAME=agent-enterprise-boilerplate
# Runtime environment: development, testing, or production.
APP_ENV=development
# Log directory. Relative paths resolve from the working directory.
LOG_DIR=logs
# Log level such as DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO
# Log format: auto uses pretty logs in development and JSON logs in production.
LOG_FORMAT=auto
# Default model provider.
DEFAULT_MODEL_PROVIDER=openai
# Default model name.
MODEL_NAME=gpt-4o-mini
# OpenAI API key.
OPENAI_API_KEY=
# Optional OpenAI-compatible API base URL.
OPENAI_API_BASE=
# Anthropic API key.
ANTHROPIC_API_KEY=
# Google or Gemini API key. GOOGLE_API_KEY is the preferred name.
GOOGLE_API_KEY=
# DeepSeek API key.
DEEPSEEK_API_KEY=
# Tavily API key used by an optional search integration.
TAVILY_API_KEY=
